generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Audit {
  id             String   @id @default(cuid())
  teamSize       Int
  useCase        String
  recommendation String
  savings        Int
  createdAt      DateTime @default(now())

  tools          Tool[]
}

model Tool {
  id           String @id @default(cuid())
  tool         String
  plan         String
  monthlySpend Int
  seats        Int

  auditId String
  audit   Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)
}